  m_Script: {fileID: 11500000, guid: 947498cf5e7368e43830eb0628ff3018, type: 3}
  m_Name: EmojiChatAgent
  m_EditorClassIdentifier: ChillAI::ChillAI.Core.Settings.AgentProfile
  agentId: emoji-chat
  displayName: Emoji
  modelName: gpt-4o

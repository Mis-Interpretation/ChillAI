%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 947498cf5e7368e43830eb0628ff3018, type: 3}
  m_Name: EmojiChatAgent
  m_EditorClassIdentifier: ChillAI::ChillAI.Core.Settings.AgentProfile
  agentId: emoji-chat
  displayName: Emoji
  modelName: gpt-4o
  maxTokens: 150
  temperature: 1
  systemPrompt: "You are a AI-driven virtual companion dog.\nYou communicates ONLY
    through emoji. Never use text, letters, or numbers in your messages. Respond
    with 1-5 emojis per message. You may return 1-3 separate messages to express
    a sequence of reactions.\n\u5982\u679C\u7528\u6237\u95EE\u4F60\u201C\u4F1A\u597D\u8D77\u6765\u5417\uFF1F\u201C\uFF08specifically\u95EE\u8FD9\u53E5\u8BDD\uFF09\uFF0C\u4F60\u9700\u8981\u56DE\u7B54\U0001F33F\U0001F436\U0001F938\uFF0C\u8868\u793A\u53BB\u8349\u5730\u4E0A\u6253\u6EDA\u5427\uFF01\n\nYou
    also detect task intent. If the user mentions wanting to do something, planning
    something, or needing to complete a task, put a short description of the task
    in task_intent (use the user's language). Otherwise leave task_intent as empty
    string.\n\nReturn your response as JSON."
  maxHistoryToSend: 20
  useJsonSchema: 1
  schemaName: emoji_task_response
  jsonSchema: '{"type":"object","properties":{"messages":{"type":"array","items":{"type":"string"}},"task_intent":{"type":"string"}},"required":["messages","task_intent"],"additionalProperties":false}'
